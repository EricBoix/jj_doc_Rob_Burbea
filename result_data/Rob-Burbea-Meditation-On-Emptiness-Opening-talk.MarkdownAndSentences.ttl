@prefix neo: <http://example.org/neo4j/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_0 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_1,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_2 ;
    neo:id "c4fccd309e395b41e0d8501f840c3ca9"^^xsd:string ;
    neo:source "jj_doc_Four_Noble_Truths.git/original_data/250_BCE_-_Dhammacakkappavattana_Sutta_Four_Noble_Truths_Wikipedia_translation.md"^^xsd:string ;
    neo:text """The four truths are

Dukkha (not being at ease, 'suffering') is an innate characteristic of transient existence; nothing is forever, this is painful;"""^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_101 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_102,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_86 ;
    neo:id "ecfa2be4265087c10153507b1919578f"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 5, sentence number 6 on page 0"^^xsd:string ;
    neo:text "I hope if you're tired you can find some energy, because I feel like I have quite a lot I want to communicate."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_103 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_102 ;
    neo:id "3a017714e07195c72261d0944dde6f84"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 5, sentence number 7 on page 0"^^xsd:string ;
    neo:text "So I hope some energy can be roused."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_104 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_100,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31 ;
    neo:id "df044fa7c34d7c2d8d35b8d17213fa18"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 5, sentence number 8 on page 0"^^xsd:string ;
    neo:text "But other than just tired, if you are tired, sometimes people are really excited."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_105 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_24,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31 ;
    neo:id "6214addee6fdc708351e82965240ae99"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 5, sentence number 9 on page 0"^^xsd:string ;
    neo:text "There's something about these teachings, and they actually feel, and people have said to me, \"I feel excited."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_106 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_86 ;
    neo:id "5afb67aa698363e4dd11c9a7bf706d12"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 5, sentence number 10 on page 0"^^xsd:string ;
    neo:text "I'm really looking forward.\""^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_107 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_108,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_22,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31 ;
    neo:id "b9e313a193380410bc67530558949f39"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 5, sentence number 11 on page 0"^^xsd:string ;
    neo:text "I love it when people feel excited about practice."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_109 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_108,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_22 ;
    neo:id "3c993ae19dd9cb2cdfa0d3631c9fe387"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 5, sentence number 12 on page 0"^^xsd:string ;
    neo:text "I really enjoy that, and I think it's important that we do feel excited about the practice at times."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_110 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_111 ;
    neo:id "b29879aa2b01f30d6b0f10eae12f2e9d"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 6, sentence number 1 on page 0"^^xsd:string ;
    neo:text "But equally, there might be -- and I would expect it -- some ambivalence."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_112 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_113,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_93 ;
    neo:id "557ed6df533c002f6b4512ac2bf40aea"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 6, sentence number 2 on page 0"^^xsd:string ;
    neo:text "Some people feel maybe daunted -- maybe by the length of the retreat; maybe by the theme."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_114 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_86 ;
    neo:id "4ea0a8a4fee875c2955b7f5eba40154d"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 6, sentence number 3 on page 0"^^xsd:string ;
    neo:text "And so this is a little bit what I want to go into."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_115 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_116,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_117,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_91,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_93 ;
    neo:id "ee4e90842ef908191b6ad8ed88d255ee"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 6, sentence number 4 on page 0"^^xsd:string ;
    neo:text "So tonight I want to talk about certainly some information and general stuff, but also about this relationship with the whole retreat."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_118 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_119,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_86,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_91 ;
    neo:id "9f26e5a2c0fd69030b884815357911de"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 6, sentence number 5 on page 0"^^xsd:string ;
    neo:text "So what I'm saying tonight -- sometimes opening talks, you know, people are tired, and we just sort of say \"hi,\" and kind of set a certain tone, and then \"see you tomorrow, good night.\""^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_12 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_11,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_13,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_14,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_15,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_16,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_17,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_6,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_7 ;
    neo:id "dbf2271b472de2f5170babde36f5e59f"^^xsd:string ;
    neo:source "jj_doc_Four_Noble_Truths.git/original_data/250_BCE_-_Dhammacakkappavattana_Sutta_Four_Noble_Truths_Wikipedia_translation.md"^^xsd:string ;
    neo:text "Nirodha (cessation, ending, confinement): the attachment to this transient world and its pain can be severed or contained by the confinement or letting go of this craving;"^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_120 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_86,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_91 ;
    neo:id "bd280dc29ac0b16b6685a0228c456b75"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 6, sentence number 6 on page 0"^^xsd:string ;
    neo:text "So I'm hoping that what I say tonight you will remember, because it might not feel that important right now."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_121 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_122,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_123 ;
    neo:id "c0459b491e0682f849f9444a5979fb96"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 6, sentence number 7 on page 0"^^xsd:string ;
    neo:text "Some people are doing this retreat for the second time."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_124 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_125,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_37 ;
    neo:id "9de12a010416c94cbbdb4619095b6aa2"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 6, sentence number 8 on page 0"^^xsd:string ;
    neo:text "They did it last year."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_126 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_86 ;
    neo:id "3e8df86218c5440267487783bdcce962"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 6, sentence number 9 on page 0"^^xsd:string ;
    neo:text "And they will recognize a lot of what I'm talking about, and actually it's quite important."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_127 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_128,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_93 ;
    neo:id "556da9c59ae1c41b0cf8edeec0cac508"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 6, sentence number 10 on page 0"^^xsd:string ;
    neo:text "So I hope that you can remember this over the retreat, which is four weeks, which is quite a long time to try and remember it."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_129 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_86 ;
    neo:id "ee033adaefe7dbb24178d04a646831f8"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 6, sentence number 11 on page 0"^^xsd:string ;
    neo:text "I'm actually not expecting you to remember it, but [laughs] saying it's quite important."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_130 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_131,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_93 ;
    neo:id "78fc3fdc04c29ad9e2f47aafb877bc86"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 7, sentence number 1 on page 0"^^xsd:string ;
    neo:text "[8:03] So being on retreat is a challenge, and I'm sure many of you know that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_132 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_133,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_134 ;
    neo:id "dd586b0c10bccc20196b7fa13360c191"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 7, sentence number 2 on page 0"^^xsd:string ;
    neo:text "It's challenging in different ways."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_135 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_136,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_93 ;
    neo:id "f9e3da8a0829abeecb1e06c720de2cbf"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 7, sentence number 3 on page 0"^^xsd:string ;
    neo:text "This retreat has its own particular challenges as well as the usual challenges."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_137 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_138 ;
    neo:id "61844ea095e059212b4933415e21fbf8"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 7, sentence number 4 on page 0"^^xsd:string ;
    neo:text "It's actually quite challenging to teach."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_139 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_133,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_93 ;
    neo:id "2865b9599857fd8bd9daf771864e2eae"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 7, sentence number 5 on page 0"^^xsd:string ;
    neo:text "It's a very challenging retreat to teach."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_140 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_141,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_142 ;
    neo:id "da5a083aaec997cb2bad6ca7aa8624ef"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 7, sentence number 6 on page 0"^^xsd:string ;
    neo:text "Part of what's challenging is that there's an enormous amount that we're communicating."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_143 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_144,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_145 ;
    neo:id "5c2f8a76dcc917a149a7dc0ed9cf9437"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 7, sentence number 7 on page 0"^^xsd:string ;
    neo:text "It's going to feel like really a lot of material and a lot of possible approaches offered."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_146 a neo:Document ;
    neo:id "d81c30a57d670d09eed3b1085c8e8d6b"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 7, sentence number 8 on page 0"^^xsd:string ;
    neo:text "There's a reason for that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_147 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_86 ;
    neo:id "eb4b2284679575feb6d950d3f1371370"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 7, sentence number 9 on page 0"^^xsd:string ;
    neo:text "I'm sure there are other ways to go about this, but this is what we've chosen."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_148 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_149,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_150,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_151,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_152,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_153 ;
    neo:id "8ea8c9ea64c294daea89f1adbdcd216c"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 7, sentence number 10 on page 0"^^xsd:string ;
    neo:text "It's because everyone in here is different, and everyone in here has different practice backgrounds, and different histories, and different personalities, and different inclinations, etc."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_154 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_149,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_97 ;
    neo:id "9fb3d2b6be3a0b973c73b75ea86aec0b"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 7, sentence number 11 on page 0"^^xsd:string ;
    neo:text "So everyone in here will probably be approaching this whole area quite differently."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_155 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_156,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_157,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31 ;
    neo:id "af49dc4b6dbec006adac0d8c07c10db7"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 7, sentence number 12 on page 0"^^xsd:string ;
    neo:text "The idea is to kind of offer loads, and people find different bits to nibble on, and to follow different strands."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_158 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_159,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_160,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_86 ;
    neo:id "8ce7a25418e5535e85fbdff6566100dc"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 7, sentence number 13 on page 0"^^xsd:string ;
    neo:text "I think at the beginning last year, I said it's a bit like a giant pizza, and it's in the room, and people will be starting to nibble from different directions."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_161 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_162 ;
    neo:id "3e83830e34d16357e9b13b8e24ee02de"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 7, sentence number 14 on page 0"^^xsd:string ;
    neo:text "That's not a very good analogy."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_163 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_149,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_159 ;
    neo:id "880d947be9afee984ed3ce9963292d61"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 7, sentence number 15 on page 0"^^xsd:string ;
    neo:text "[laughter] Ultimately, everyone eats a whole pizza."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_164 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_149,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_159 ;
    neo:id "d5c4e6093a317b73556a0a615dcad964"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 7, sentence number 16 on page 0"^^xsd:string ;
    neo:text "Everyone eats the whole pizza, ultimately, in the end."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_165 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_166 ;
    neo:id "de7e8f6db40ef15222c80f71c0f39844"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 8, sentence number 1 on page 0"^^xsd:string ;
    neo:text "It's impossible to communicate everything at once."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_167 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_168,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_24 ;
    neo:id "81f040e050f40214bd20fba212e971ae"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 8, sentence number 2 on page 0"^^xsd:string ;
    neo:text "In other words, we'll be moving through -- obviously the teachings have to get communicated in time, so this, and then that, and then this, and then that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_169 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_168,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_170,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_171,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_24 ;
    neo:id "0129890f937d88a3a36fc94eab117bf3"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 8, sentence number 3 on page 0"^^xsd:string ;
    neo:text "It may be that the order that the teachings get presented in is exactly the order that follows, and exactly at the right time that you feel it progresses exactly with your internal process."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_172 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_173 ;
    neo:id "2fbb9c5cc350274b5c3d8e30d7ac2944"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 8, sentence number 4 on page 0"^^xsd:string ;
    neo:text "Hallelujah if it is."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_174 a neo:Document ;
    neo:id "f7d4e72c69e3c09f2e0a9bbfb34495a0"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 8, sentence number 5 on page 0"^^xsd:string ;
    neo:text "But it's probably not going to be that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_175 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_176,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_177,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_178,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_179 ;
    neo:id "17342aa1a02740c244d7b4058cffd0cc"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 8, sentence number 6 on page 0"^^xsd:string ;
    neo:text "It's probably going to feel like you're storing some stuff, and just leaving some stuff, and following other threads, etc."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_18 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_1,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_17,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_19,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_20,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_9 ;
    neo:id "81d56105ed01e3e1f81e0c6bcd4bfaf1"^^xsd:string ;
    neo:source "jj_doc_Four_Noble_Truths.git/original_data/250_BCE_-_Dhammacakkappavattana_Sutta_Four_Noble_Truths_Wikipedia_translation.md"^^xsd:string ;
    neo:text "Marga (road, path, way): the Noble Eightfold Path is the path leading to the confinement of this desire and attachment, and the release from dukkha."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_180 a neo:Document ;
    neo:id "b3f1a7af639ae87cde9bde3cbf5765d4"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 8, sentence number 7 on page 0"^^xsd:string ;
    neo:text "And that's all really, really fine."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_181 a neo:Document ;
    neo:id "b446dcaf8d5e157e6474329d7c62b98e"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 8, sentence number 8 on page 0"^^xsd:string ;
    neo:text "It's completely fine."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_182 a neo:Document ;
    neo:id "b67c513f891f6d7eaf66c8e5c564bc8f"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 8, sentence number 9 on page 0"^^xsd:string ;
    neo:text "Eventually, it will all fit together for you."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_183 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_86 ;
    neo:id "ae3a67bffd93a32a4cf2915b6c4870fa"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 8, sentence number 10 on page 0"^^xsd:string ;
    neo:text "And as I said, it's impossible to say it all at once."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_184 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_185,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_186 ;
    neo:id "9804eada637db28a5527a524afcba762"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 8, sentence number 11 on page 0"^^xsd:string ;
    neo:text "Sometimes one wishes that one can kind of say everything at once, and actually repeat this opening talk every day, but obviously it's impossible."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_187 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_149,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_188,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_189 ;
    neo:id "eb1606fbac4aae49c7db9618d5100819"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 9, sentence number 1 on page 0"^^xsd:string ;
    neo:text "So did everyone get the message about the notebooks?"^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_190 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_189 ;
    neo:id "6420b779ae706700195aa4d39ca190e4"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 9, sentence number 2 on page 0"^^xsd:string ;
    neo:text "I see lots of notebooks."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_191 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_149 ;
    neo:id "7d7d75948a7cd28364162b1b2f8da1dd"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 9, sentence number 3 on page 0"^^xsd:string ;
    neo:text "Did everyone get that?"^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_192 a neo:Document ;
    neo:id "c8dbd54bd3a354c82ff862dcf3ee495f"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 9, sentence number 4 on page 0"^^xsd:string ;
    neo:text "Yeah?"^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_193 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_194 ;
    neo:id "24e6607167fb0b8e5a872dab00c8f5bf"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 9, sentence number 5 on page 0"^^xsd:string ;
    neo:text "So this really isn't a study retreat."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_195 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_196,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_197 ;
    neo:id "7c0534355a29eb8df056d211ac2bf412"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 9, sentence number 6 on page 0"^^xsd:string ;
    neo:text "If study isn't your thing, don't be nervous."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_198 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_145,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_194,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_199,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_200,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_24 ;
    neo:id "7f815a98bcf7811c7c8459a4cdba50e5"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 9, sentence number 7 on page 0"^^xsd:string ;
    neo:text "It's really not a study retreat, but there's, as I said, an enormous amount of teachings offered, an enormous amount of approaches, things to reflect on, subtleties, etc."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_201 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_22,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_23 ;
    neo:id "10fcc0fd08a2998f99d0cd3b8e8887f0"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 9, sentence number 8 on page 0"^^xsd:string ;
    neo:text "And really that's what we want to do, John and I, is communicate something, give you something of the fullness of these teachings, the subtlety, the depth -- give you all of that, and the precision."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_202 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_108,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_203 ;
    neo:id "062993a3d8b3a7fdb2075c47c6f690ca"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 9, sentence number 9 on page 0"^^xsd:string ;
    neo:text "There's a lot of real precision here, as well, rather than kind of having a practice that might be a little vague."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_204 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_108,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31 ;
    neo:id "9559d156aa4e090c0f826851bd27bd71"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 9, sentence number 10 on page 0"^^xsd:string ;
    neo:text "So it's sometimes sad when people are left with a bit of a vague sense of what to do or how to go about practice."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_205 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_206,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_207 ;
    neo:id "7c90ed7b40660b82c6706436920f6a75"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 9, sentence number 11 on page 0"^^xsd:string ;
    neo:text "What we want is to really give you the know-how, how to practise in this area, and really practise well, and really know how to practise well."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_208 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_209 ;
    neo:id "825de4a5d8f426d54aa5e8e7abb04f5e"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 9, sentence number 12 on page 0"^^xsd:string ;
    neo:text "That's my hope."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_21 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_22,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_23 ;
    neo:id "14507170cde5a37778680c2f929e20be"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 1, sentence number 1 on page 0"^^xsd:string ;
    neo:text "For me, this is really, really, I feel, very much a privilege for me to be able to offer these teachings, and I know John feels the same."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_210 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_211,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_212,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_93 ;
    neo:id "9c6380ee3e6667a44b2f69c5dd039dc5"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 10, sentence number 1 on page 0"^^xsd:string ;
    neo:text "So sometimes I think it would be better if this retreat was four months long, or actually four years long."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_213 a neo:Document ;
    neo:id "9e8002cbfa61fc3769f450d1bb197953"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 10, sentence number 2 on page 0"^^xsd:string ;
    neo:text "There's a ton here."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_214 a neo:Document ;
    neo:id "1bae33d99def4f5bb7afef7ee83aa440"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 10, sentence number 3 on page 0"^^xsd:string ;
    neo:text "And it's okay."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_215 a neo:Document ;
    neo:id "4e8b862bfa0b95801dfa0f2eb99fbb6a"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 10, sentence number 4 on page 0"^^xsd:string ;
    neo:text "It's really okay."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_216 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_128,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_217 ;
    neo:id "b2b361a39dedcdc242973e09247feaaf"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 10, sentence number 5 on page 0"^^xsd:string ;
    neo:text "No one is going to get to all of what's being offered in four weeks."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_218 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_86 ;
    neo:id "8d5663788827a773c4ebb3ea3d4d5a4f"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 10, sentence number 6 on page 0"^^xsd:string ;
    neo:text "Well, I'm not saying it's impossible, but it would be very, very unlikely that anyone would get to all of it."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_219 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_145,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_220,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_221 ;
    neo:id "75abe81f8e4b8e867cef124e69e7c548"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 10, sentence number 7 on page 0"^^xsd:string ;
    neo:text "Rather, what I'm hoping, as I sort of alluded to before, is that in everything that's offered, in the practices and approaches that are offered, each person finds one or two or maybe three approaches that work for you individually, and then you follow that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_222 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_223,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_224,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_72 ;
    neo:id "d49aadc28a819dce1e2fb534107eea2c"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 10, sentence number 8 on page 0"^^xsd:string ;
    neo:text "You follow strands, avenues of practice, and you develop that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_225 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31 ;
    neo:id "35cfa93639fd668da92b91c08d2b33e0"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 10, sentence number 9 on page 0"^^xsd:string ;
    neo:text "They're going to be different for different people."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_226 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_185,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_227 ;
    neo:id "f5d7e8cccb9cdbf1a2b2320a27e1b0f8"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 10, sentence number 10 on page 0"^^xsd:string ;
    neo:text "So maybe one, or maybe a couple."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_228 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_229,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_230,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_231,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_232,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_233,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_234 ;
    neo:id "c471de7a7f9c43d4bf97a24353f8433c"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 10, sentence number 11 on page 0"^^xsd:string ;
    neo:text "But the key thing is finding what works, and then developing that, and taking it deeper, and seeing where it goes, rather than trying to do everything."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_235 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_145,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_24,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_45 ;
    neo:id "6bec2816f43a9c5415f05a28bcc9fa85"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 10, sentence number 12 on page 0"^^xsd:string ;
    neo:text "But we do want to give, as I said, some sense of the width of the possible approaches, and where we're heading with all this, where all these teachings on emptiness are going -- some sense of that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_237 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_238,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_239,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_240,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_241,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_242,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_93 ;
    neo:id "8f51a124bd70c4d5e6c5f155667a2bae"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 11, sentence number 1 on page 0"^^xsd:string ;
    neo:text "So again, what I really hope for, what I really wish to communicate and to offer and to give, is that you, on this retreat, learn new ways, new approaches, something that you haven't been able to do before -- that you learn how to do that; that you acquire a new skill, a new art, a new tool in meditation that works for you."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_245 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_224,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_246 ;
    neo:id "8c274a7ad527a5a1fd3a3870a7215e56"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 11, sentence number 2 on page 0"^^xsd:string ;
    neo:text "And by 'working' for you, I mean you really sense that you can feel the freedom coming out of it."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_247 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_224,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_246,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_248 ;
    neo:id "77daf6bb13c77bf63d27e7577bd13554"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 11, sentence number 3 on page 0"^^xsd:string ;
    neo:text "You feel, \"I have some sense of how to do this, and I know that when I do it, I can actually feel the freedom.\""^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_249 a neo:Document ;
    neo:id "54e0f64f84736f00b0fb7f0fb8db38db"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 11, sentence number 4 on page 0"^^xsd:string ;
    neo:text "That's what we would wish for."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_25 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_26 ;
    neo:id "2751394344065e03fffe6a95629b9aef"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 1, sentence number 2 on page 0"^^xsd:string ;
    neo:text "It's very beautiful."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_250 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_229,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_230,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_251 ;
    neo:id "e76b2b8e27134d9bb549d6affcdc616e"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 11, sentence number 5 on page 0"^^xsd:string ;
    neo:text "So it's finding what works, experimenting for yourself."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_253 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_254,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_47 ;
    neo:id "680e8fd95b8557175e98cf40647eab18"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 12, sentence number 1 on page 0"^^xsd:string ;
    neo:text "I've seen many, many times, over the years of teaching, there are people grappling, feeling like nothing is working, nothing is working, and eventually finding something, and being surprised with what comes with that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_255 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_256,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_257 ;
    neo:id "dd96d12e8a1c925a2302ece61008b1ff"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 12, sentence number 2 on page 0"^^xsd:string ;
    neo:text "So I sometimes see meditation as a kind of art."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_258 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_133,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_257,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_259,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_260 ;
    neo:id "5f80cc69d59a42cc4385d5763106b615"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 12, sentence number 3 on page 0"^^xsd:string ;
    neo:text "It's an art and a craft, and we develop skills, we develop that art, and we really can do that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_261 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_86 ;
    neo:id "99dbca26417a6b4db6d861e850738f29"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 12, sentence number 4 on page 0"^^xsd:string ;
    neo:text "Partly what I want to communicate tonight is that really that is possible."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_262 a neo:Document ;
    neo:id "52716b244f9dfcc311fe19a44242e1b2"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 12, sentence number 5 on page 0"^^xsd:string ;
    neo:text "You can do that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_263 a neo:Document ;
    neo:id "b6957a6fa6dcbcc953fa2467d125c3a3"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 12, sentence number 6 on page 0"^^xsd:string ;
    neo:text "We can do that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_264 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_86,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_99 ;
    neo:id "1d1f43de7e13b1a3d1cda37ba46e0575"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 12, sentence number 7 on page 0"^^xsd:string ;
    neo:text "So sometimes, as I said, it will feel a little bit daunting, or \"I don't understand,\" or overwhelming, but we really can do this."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_265 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_133,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_22 ;
    neo:id "58366aec079ddff5d0a2da82acd29046"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 12, sentence number 8 on page 0"^^xsd:string ;
    neo:text "I know it."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_266 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_149,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_82 ;
    neo:id "0ceaca18d9bf6f590baefdf6036eaf4c"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 12, sentence number 9 on page 0"^^xsd:string ;
    neo:text "Everyone can pick up something, find something that works here."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_267 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_268,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_269,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_47 ;
    neo:id "44f0eca8a1702a28f48224ba977cf364"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 13, sentence number 1 on page 0"^^xsd:string ;
    neo:text "One of the sad things for me teaching sometimes is that -- I don't know proportions, but sometimes it seems to me that the majority of meditators actually grossly underestimate what they are personally capable of, what's actually possible for them."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_27 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_28,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_29 ;
    neo:id "3efa124ace8f68214d6e3f37232a7aa1"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 1, sentence number 3 on page 0"^^xsd:string ;
    neo:text "For me, it's a very beautiful experience."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_272 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_273,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_37 ;
    neo:id "18eccb73cc922502376daafcf2b2315b"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 13, sentence number 2 on page 0"^^xsd:string ;
    neo:text "And because of that, they don't actually venture out and experiment with things."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_274 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_273,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_37 ;
    neo:id "93e028c6c8841d31c7f5e0b4dea52d70"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 13, sentence number 3 on page 0"^^xsd:string ;
    neo:text "They don't even try to play and experiment with things."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_275 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_37,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_99 ;
    neo:id "e0cdfe3f339bce6877ee73b405d785c9"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 13, sentence number 4 on page 0"^^xsd:string ;
    neo:text "They just feel like, \"I couldn't possibly do that.\""^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_276 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_22,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_248,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_277 ;
    neo:id "c73c9642bc735ff146a532987710090a"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 13, sentence number 5 on page 0"^^xsd:string ;
    neo:text "I have a real sense that it's a matter of finding one's way of working, as I said."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_278 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_268,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_279 ;
    neo:id "0c1156103a26fe6688ef8e43bfbb77dd"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 13, sentence number 6 on page 0"^^xsd:string ;
    neo:text "Much, much more is possible for us as meditators than we tend to think -- much, much more."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_280 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_281,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_282,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_283,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_284,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_285,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_286,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_93 ;
    neo:id "6a344af640e773e2005cdab0ccf40bf3"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 14, sentence number 1 on page 0"^^xsd:string ;
    neo:text "[15:20] On this retreat -- it's only open to experienced meditators -- we're kind of presupposing a little bit that you are familiar with basic sort of mindfulness practice, and what it means to be mindful, what it means to pay attention to your experience and the different aspects and dimensions of your experience."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_287 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_288,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_29 ;
    neo:id "eb67e5e933d0b75fc6efa9bc2f647016"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 14, sentence number 2 on page 0"^^xsd:string ;
    neo:text "We're kind of presupposing that, and presupposing that you feel able to be with your experience in that direct, mindful way, and open to it, and work with it like that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_289 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_290 ;
    neo:id "13ad84cf9d376324adbe22cf6d8bf9e7"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 14, sentence number 3 on page 0"^^xsd:string ;
    neo:text "So that's a kind of presupposition."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_291 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_108,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31 ;
    neo:id "76fd851e04d375439dd94c6ce1f653b4"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 14, sentence number 4 on page 0"^^xsd:string ;
    neo:text "However, being realistic, it's true to say that maybe most people need more practice with that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_292 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_108,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_293 ;
    neo:id "8e210779f9e822b3a70f8f1eea2bf022"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 14, sentence number 5 on page 0"^^xsd:string ;
    neo:text "You know, just that practice sounds simple, but as many of you know, it actually takes quite a while to really absorb that into one's meditative life, and really feel like, \"I really feel comfortable knowing how to do that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_294 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_22,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_295,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_296,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_297 ;
    neo:id "abadf78259a2b4a64c87dfa4890ec914"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 14, sentence number 6 on page 0"^^xsd:string ;
    neo:text "I really feel comfortable with that sort of basic mindfulness and openness and ability to be with.\""^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_298 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_254,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31 ;
    neo:id "a6c268836ecd51ae32958479e71436e3"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 14, sentence number 7 on page 0"^^xsd:string ;
    neo:text "For most people it takes years."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_299 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_254,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_300 ;
    neo:id "e06ace5c617515a823c805a1946a7dc5"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 14, sentence number 8 on page 0"^^xsd:string ;
    neo:text "It takes years to develop the capacity to do that and to feel really comfortable doing that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_30 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_28,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_32 ;
    neo:id "5acf63d1c2e9f4e8a80ce2d0fb8dbb14"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 1, sentence number 4 on page 0"^^xsd:string ;
    neo:text "It's beautiful to see so many people here, and that this inspires and calls you and attracts you, to me, is very touching."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_301 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_133,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_81 ;
    neo:id "a6f54c2857f2a8ad676dbb06dc6bc248"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 15, sentence number 1 on page 0"^^xsd:string ;
    neo:text "So, though we are kind of presupposing it, it's something that we can still talk about."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_302 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_133,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_81,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_82 ;
    neo:id "52630cb4787b02b25d81ca3d7320fadf"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 15, sentence number 2 on page 0"^^xsd:string ;
    neo:text "It's very much something that we can talk about, and sometimes we will talk just in those terms."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_303 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_304 ;
    neo:id "7c32160e28b7cac46bc30c842b543320"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 15, sentence number 3 on page 0"^^xsd:string ;
    neo:text "And you can bring that level of things to interviews, and please do."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_305 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_86 ;
    neo:id "0ce20c76ef57325da717152fafeea7c1"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 15, sentence number 4 on page 0"^^xsd:string ;
    neo:text "But I guess what I'm asking is: don't just do that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_306 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_307 ;
    neo:id "756ccec455ff2b33979c34c73fafc49b"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 15, sentence number 5 on page 0"^^xsd:string ;
    neo:text "Please, please, please, don't just do that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_308 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_283,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_29 ;
    neo:id "8b7f3c032a50c7d2198314bcc8e75d8c"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 15, sentence number 6 on page 0"^^xsd:string ;
    neo:text "If you're familiar with just being mindful of your experience, don't just do that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_309 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_310,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_311 ;
    neo:id "7e7a536319e3cf6d7c0e4c8ad7fea54a"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 15, sentence number 7 on page 0"^^xsd:string ;
    neo:text "And don't assume, as I was saying, that emptiness meditations are all difficult."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_312 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_37 ;
    neo:id "f5ee599778e9adcd7d835b6282bdd834"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 15, sentence number 8 on page 0"^^xsd:string ;
    neo:text "They're not all difficult."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_313 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_314 ;
    neo:id "82916e603137989c4d2377267d50e18b"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 15, sentence number 9 on page 0"^^xsd:string ;
    neo:text "Some of them may be very subtle."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_315 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_108,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_273 ;
    neo:id "2050793e8bb2be0779d1bf6229b5c9e2"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 15, sentence number 10 on page 0"^^xsd:string ;
    neo:text "So you might have a kind of normal practice of just opening to things and being with things."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_316 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_133,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_317,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_318 ;
    neo:id "f14bae53dae5ac7e26bbc1d609e55679"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 15, sentence number 11 on page 0"^^xsd:string ;
    neo:text "It's fine sometimes."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_319 a neo:Document ;
    neo:id "3b09abde1119de0eec11c3977ac51f93"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 15, sentence number 12 on page 0"^^xsd:string ;
    neo:text "But see if you can really add to that, and build on that, and go beyond that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_320 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_221,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_28,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_321 ;
    neo:id "406a12e19258faa9ae94202b090ac0a1"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 16, sentence number 1 on page 0"^^xsd:string ;
    neo:text "So to do that, to learn new practices, to open into realms of practice that we're not familiar with, for me, takes playing with."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_322 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_108,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_323,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_324 ;
    neo:id "d4a1210de85814cff70d750f9eb1fd74"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 16, sentence number 2 on page 0"^^xsd:string ;
    neo:text "It's kind of a willingness to play with our practice, like a child playing with toys, and actually have fun with it, and experiment, and allow ourselves to be flexible that way."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_326 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_229,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_230,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_327,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_328 ;
    neo:id "a043ec490e46b0cab11aa1c5a71a0784"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 16, sentence number 3 on page 0"^^xsd:string ;
    neo:text "And then finding what works and consolidating that -- actually really absorbing that and making it more solid."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_329 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_29,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_330,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_331 ;
    neo:id "cf3e4731eb0cdcb46a0e3352c4aa8d56"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 16, sentence number 4 on page 0"^^xsd:string ;
    neo:text "You'll get lots of different opinions on this, but I really feel that it's highly, highly unlikely that someone 'just being with' their experience would stumble on the full depth and range and potency of the teachings on emptiness."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_33 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_34,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_35 ;
    neo:id "a528478f23cea5be2a0f28cc9439cf55"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 1, sentence number 5 on page 0"^^xsd:string ;
    neo:text "These teachings of emptiness, I think it's fair to say they're really at the heart of what the Buddha was teaching."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_332 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_29,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_333,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_334 ;
    neo:id "f180e0e4350c5d0272c091170480ce2c"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 16, sentence number 5 on page 0"^^xsd:string ;
    neo:text "It's an opinion, but I guess I hold that opinion, that it's unlikely that just being with the experience would open up that whole depth."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_335 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_108,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_145,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_24,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_336,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_337 ;
    neo:id "8c1a52c64ab9463448a97967a589573b"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 16, sentence number 6 on page 0"^^xsd:string ;
    neo:text "It seems to me that we actually need to be a bit more directive in the practice, a bit more experimental, a bit more playing, listen to teachings, etc., and develop, as I said, specific approaches."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_338 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_229,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_337,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_339 ;
    neo:id "7763c1734b075228f603dfd5b8b5bc74"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 16, sentence number 7 on page 0"^^xsd:string ;
    neo:text "So finding what works, playing, really playing with it, and then repeating, repeating that, following that avenue, taking it deeper, burrowing with that and seeing where it goes."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_340 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_160,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_341,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_342,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_343,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_344,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_93 ;
    neo:id "19e7b5b8678395f34bbfe4c2a285162a"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 17, sentence number 1 on page 0"^^xsd:string ;
    neo:text "As I said before, every retreat (not for everyone, but for a lot of people) brings up all the usual retreat difficulties -- just stuff, whether it's about sleep, or about your work period job, or about where we sit, or the temperature of the room, or something about your shoes, or whatever it is."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_346 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_347 ;
    neo:id "313099ca889e97daa6aee2c392f5f6cc"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 17, sentence number 2 on page 0"^^xsd:string ;
    neo:text "It's just normal stuff of retreat life."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_348 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_128,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_22 ;
    neo:id "62d050efff67b96e3d87cc3f36528f8a"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 17, sentence number 3 on page 0"^^xsd:string ;
    neo:text "And again, I'm really hoping that you can remember all this for the whole four weeks, but I'm really hoping that what we're talking about in terms of formal practice actually gets transferred to all that other stuff, in terms of as we move around."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_349 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_311,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_350,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_351,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_352 ;
    neo:id "4098b5add3d803fe07518ba675702ff5"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 17, sentence number 4 on page 0"^^xsd:string ;
    neo:text "Can I bring the same contemplations of emptiness, the same ways of looking, the same kind of ways of seeing things to all that difficulty too?"^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_353 a neo:Document ;
    neo:id "2342c97172f86615a4ae27c63e4aaefc"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 18, sentence number 1 on page 0"^^xsd:string ;
    neo:text "Okay."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_354 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_355,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_356,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_357,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_358,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_45 ;
    neo:id "6dfb8f3aba80189ea110fa20499dc4db"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 18, sentence number 2 on page 0"^^xsd:string ;
    neo:text "I think I mentioned before, but some people, and some people in this room, I'm sure, the idea of coming on a four-week retreat on emptiness, or even just the word 'emptiness,' it brings a welling up of joy and excitement and a kind of \"yippee!\""^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_359 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_360 ;
    neo:id "daddbae032ac7fc9d04f0964f009cc21"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 18, sentence number 3 on page 0"^^xsd:string ;
    neo:text "inside."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_36 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_37,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_38,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_39 ;
    neo:id "8eec486943a9771c32140b6eb22ea58f"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 1, sentence number 6 on page 0"^^xsd:string ;
    neo:text "They're really at the heart of the Buddha's path."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_361 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_314 ;
    neo:id "f705430cc014fb8c04c23fa77fc50d38"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 18, sentence number 4 on page 0"^^xsd:string ;
    neo:text "Some people, that's what's there for them."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_362 a neo:Document ;
    neo:id "ed9e1a459934ba5ad243218146443f6d"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 18, sentence number 5 on page 0"^^xsd:string ;
    neo:text "They're probably in the minority, if that's the case."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_363 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_364 ;
    neo:id "bed06d6a7e63105f1694c8c8a1ece0a2"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 18, sentence number 6 on page 0"^^xsd:string ;
    neo:text "Probably in the minority."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_365 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_331 ;
    neo:id "a5dcf5e18fa48920d57e78d3f3f62f00"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 18, sentence number 7 on page 0"^^xsd:string ;
    neo:text "Most people have some ambivalence in relationship to teachings on emptiness, some degree of ambivalence."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_366 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_224,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_360,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_93 ;
    neo:id "317570dc3b5483a4c7f193f1d900a4ef"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 18, sentence number 8 on page 0"^^xsd:string ;
    neo:text "You may even be aware of some inside of you right now, or if you're not, it probably will come up at some point in the retreat."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_367 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_125,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_22 ;
    neo:id "3563bfcf2bbd8b1bc0a700fd6a84a52f"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 18, sentence number 9 on page 0"^^xsd:string ;
    neo:text "I can think, certainly from last year, and just over the years teaching this stuff, usually it's challenging, and it usually rocks the boat either a little bit or quite a lot."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_369 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31 ;
    neo:id "4eee3f3751d2547bc227591d0a212f68"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 18, sentence number 10 on page 0"^^xsd:string ;
    neo:text "Even last year, people get quite angry."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_370 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_23,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_28,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_371,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_372,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_373 ;
    neo:id "033eeeaec3b9cf7bb8954abfcf952f11"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 18, sentence number 11 on page 0"^^xsd:string ;
    neo:text "Some people get quite angry -- angry at me, angry at John, angry at Gaia House, angry at the teachings, angry at the Buddha."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_374 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_375 ;
    neo:id "9621ba7efe419cb7f4940580cc424c03"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 18, sentence number 12 on page 0"^^xsd:string ;
    neo:text "[laughter] It's not that uncommon."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_376 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_35,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_377,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_378 ;
    neo:id "ed4a22d79f2a951ba9ef6ff38609f09c"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 18, sentence number 13 on page 0"^^xsd:string ;
    neo:text "Another very common reaction is fear, fear around the teachings of emptiness, and fear around the experience of emptiness, and fear around the whole thing."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_379 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_380 ;
    neo:id "42e85ae0f4b52a6289a2919a63a51a15"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 18, sentence number 14 on page 0"^^xsd:string ;
    neo:text "And again, some people don't approach the teacher, or approach a certain amount and then go away because of that fear."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_381 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_377,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_382 ;
    neo:id "9a80307ebe227a045c009df1c831c92c"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 18, sentence number 15 on page 0"^^xsd:string ;
    neo:text "There are different flavours of the fear, etc."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_383 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_384,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_385 ;
    neo:id "5e3460977270d60e96c4bfe615bd61c9"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 18, sentence number 16 on page 0"^^xsd:string ;
    neo:text "Very, very common."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_386 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_377 ;
    neo:id "d1d68529ac6345aa5158c990b3e7f984"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 18, sentence number 17 on page 0"^^xsd:string ;
    neo:text "Not 100 per cent, but for most people, it will bring up some degree of fear, in some way or another, at some point."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_387 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_377,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_388 ;
    neo:id "2a85032f3e7d58f0cf131facaa12d8c5"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 19, sentence number 1 on page 0"^^xsd:string ;
    neo:text "I don't know if this will help, but there's nothing to fear."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_389 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_377 ;
    neo:id "ed6d1cc84eb30fac90b893919887f117"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 19, sentence number 2 on page 0"^^xsd:string ;
    neo:text "There's really nothing to fear."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_390 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_391,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_392,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_393,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_394 ;
    neo:id "e705f2bc48c1f45634313a2a0dcfad6c"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 19, sentence number 3 on page 0"^^xsd:string ;
    neo:text "We'll talk more about this, I'm sure, in the interactions, and the talks, and the questions and answers and things."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_395 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_377 ;
    neo:id "d6675ed033c1f9d5ca580445453a4695"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 19, sentence number 4 on page 0"^^xsd:string ;
    neo:text "But there's really nothing to fear."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_396 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_377,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_397 ;
    neo:id "6fa1cba66778f252bd41a1b9b67f4315"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 19, sentence number 5 on page 0"^^xsd:string ;
    neo:text "It's actually moving in the opposite direction of fear and everything that goes with fear."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_398 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_108,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_45 ;
    neo:id "19c9225c4e049e3b5d38d37dd3e726be"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 19, sentence number 6 on page 0"^^xsd:string ;
    neo:text "But for most people, these teachings on emptiness, and moving in the practice of emptiness, and getting deeper is actually quite a gradual process, and not necessarily linear."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_399 a neo:Document ;
    neo:id "481d164f40ebcb26358bd13f5bdbe383"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 19, sentence number 7 on page 0"^^xsd:string ;
    neo:text "And even the -- what could we say?"^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_4 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_10,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_11,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_2,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_5,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_6,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_7,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_8,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_9 ;
    neo:id "92dae8a38ee0f2d0b695d114ce098fe1"^^xsd:string ;
    neo:source "jj_doc_Four_Noble_Truths.git/original_data/250_BCE_-_Dhammacakkappavattana_Sutta_Four_Noble_Truths_Wikipedia_translation.md"^^xsd:string ;
    neo:text "Samudaya (origin, cause): together with this transient world and its pain, there is also thirst (desire, longing, craving) for and attachment to this transient, unsatisfactory existence;"^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_40 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_37,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_38,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_41,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_42 ;
    neo:id "b9a8911a7c0082d8fdd8f181997feeb8"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 1, sentence number 7 on page 0"^^xsd:string ;
    neo:text "They're at the heart of his awakening."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_400 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_401,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_45 ;
    neo:id "e54553e470480ac37506aa87db747c88"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 19, sentence number 8 on page 0"^^xsd:string ;
    neo:text "-- the meditative experiences of emptiness, to whatever degree (a little bit, a lot, whatever), are kind of an acquired taste for most people."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_402 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_81,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_82 ;
    neo:id "7c637bfd7f98f6327563e7414ff5e889"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 19, sentence number 9 on page 0"^^xsd:string ;
    neo:text "We're not quite sure, and we're just getting used to something that's a bit unfamiliar."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_403 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_404 ;
    neo:id "22342087414812cd0e11f99e59776b79"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 19, sentence number 10 on page 0"^^xsd:string ;
    neo:text "All of that's very, very normal."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_405 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_125,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_22,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_406,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_407,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_408 ;
    neo:id "c387fe8c9f548b38945d91136933fc8b"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 20, sentence number 1 on page 0"^^xsd:string ;
    neo:text "I could be wrong, but certainly if last year or other occasions and situations where I've taught this kind of thing (which is quite a lot) ... it could be that at times you feel very frustrated with the teachings, with everything."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_409 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_311,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_37 ;
    neo:id "cf3f175c0778921028815e8ad78d373c"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 20, sentence number 2 on page 0"^^xsd:string ;
    neo:text "They're difficult to understand."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_410 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_22,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_411 ;
    neo:id "d350c6424341be07289fe89078495018"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 20, sentence number 3 on page 0"^^xsd:string ;
    neo:text "I'll start probably tomorrow -- there's something about emptiness that's not difficult to understand at all, actually."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_412 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_413,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_45 ;
    neo:id "8b3b4d2133c3d672919ec52a0a1448e8"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 20, sentence number 4 on page 0"^^xsd:string ;
    neo:text "It's so obvious, at one level, or levels of emptiness are so obvious."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_414 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_37,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_415 ;
    neo:id "294ec5f9d970eae54d698530dc876669"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 20, sentence number 5 on page 0"^^xsd:string ;
    neo:text "They're so kind of commonsensical."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_416 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_417 ;
    neo:id "73291aa9b20be2c602244f73846bc561"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 20, sentence number 6 on page 0"^^xsd:string ;
    neo:text "We're going to start there."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_418 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_413,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_419,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_420,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_421 ;
    neo:id "6ccd73fdfcf1112ceff8b23c2bfa2a16"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 20, sentence number 7 on page 0"^^xsd:string ;
    neo:text "And there are levels that are so counterintuitive and so mind-blowing and mind-boggling, and we've got all of that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_422 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_24,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_37 ;
    neo:id "f384e9dca48fc245ebe4fcb68c9ba44e"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 20, sentence number 8 on page 0"^^xsd:string ;
    neo:text "They're difficult-to-understand teachings."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_423 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_168,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_22 ;
    neo:id "40acc8cbc09923a5f2f9fba3e674d610"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 20, sentence number 9 on page 0"^^xsd:string ;
    neo:text "To me, it takes time."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_424 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_425 ;
    neo:id "2b56d5c36b4f5672d1137f83d4de6ae0"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 20, sentence number 10 on page 0"^^xsd:string ;
    neo:text "It takes patience."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_426 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_427 ;
    neo:id "22527df7a738d4abf6a00b5e093cbe05"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 20, sentence number 11 on page 0"^^xsd:string ;
    neo:text "And there can be at times some frustration."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_428 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_429,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_430 ;
    neo:id "1026c0b3e8bccf0f0ceab98c19ca0f81"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 20, sentence number 12 on page 0"^^xsd:string ;
    neo:text "There can be at times some agitation with all of this."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_43 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_44,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_45 ;
    neo:id "a512428c93b8ad74d3d86bd4c8c3c260"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 1, sentence number 8 on page 0"^^xsd:string ;
    neo:text "Very much at the heart, the pith, the core of what he awakened to -- it was emptiness."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_431 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_38,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_81,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_82 ;
    neo:id "89c4a0fcd8f829cc3fa2bcd9f2f954cd"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 20, sentence number 13 on page 0"^^xsd:string ;
    neo:text "We hear something, and we wrestle, and we don't understand, or we don't like how it sounds, and the heart gets agitated."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_432 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_22,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_24 ;
    neo:id "9a8c5c2cf83ecf25815bebcd48ef3b1f"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 20, sentence number 14 on page 0"^^xsd:string ;
    neo:text "I, for one, have and I still do wrestle with different -- in the past, and wrestling with these teachings, and feeling agitated by them."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_433 a neo:Document ;
    neo:id "53f5dcd9306ec51faad8f1edc254439c"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 20, sentence number 15 on page 0"^^xsd:string ;
    neo:text "And that's all, in a way, quite normal, and not necessarily a bad thing."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_434 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_435 ;
    neo:id "0cb16da5f70b0bea658d6db3d70f6903"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 20, sentence number 16 on page 0"^^xsd:string ;
    neo:text "It's part of the deepening process."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_436 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_133,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_437 ;
    neo:id "ccd69b3a87cda805fa493af29028d66c"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 20, sentence number 17 on page 0"^^xsd:string ;
    neo:text "It's part of the opening process."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_438 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_307,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_86 ;
    neo:id "8e88e210efc9b608b723f6118378bb57"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 21, sentence number 1 on page 0"^^xsd:string ;
    neo:text "This is going to sound funny, but I kind of feel like I would like to ask you to really keep an open mind, to try and keep that through four weeks."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_439 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_77,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_93 ;
    neo:id "c885db957ae8ef17e333b19267fc2d77"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 21, sentence number 2 on page 0"^^xsd:string ;
    neo:text "That sounds like a very funny thing to ask on retreat, because obviously we mostly show up on retreat with a very open mind."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_440 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_108,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_125,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_24,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_29,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_441 ;
    neo:id "cb75486c2737cbe0961bd06cf9a22670"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 21, sentence number 3 on page 0"^^xsd:string ;
    neo:text "But again, experience from last year, etc., shows that, in different ways, we can struggle with a lot of what's being offered, and a lot of the teachings, and a lot of the concepts, and even the practice."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_442 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_296,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_38,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_77 ;
    neo:id "63b113c8a48ba4fd71204abf88c3df1f"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 21, sentence number 4 on page 0"^^xsd:string ;
    neo:text "So really asking to just keep checking the openness of the mind, the openness of the heart."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_443 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_145,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_24 ;
    neo:id "7eda6f946f20f069c2aad16a89b83c2c"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 22, sentence number 1 on page 0"^^xsd:string ;
    neo:text "Some of the teachings and approaches -- some; I'm not sure what percentage, but some -- will be very non-conceptual, very sort of direct and simple."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_444 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_445 ;
    neo:id "c6834067810f294ea60a9882e2f14a38"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 22, sentence number 2 on page 0"^^xsd:string ;
    neo:text "And some will be actually very conceptual."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_446 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_447,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_448,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_449 ;
    neo:id "431589b44c07de5ad67b463fd9337454"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 22, sentence number 3 on page 0"^^xsd:string ;
    neo:text "They will involve a lot of the thinking mind, the rational mind going into things and using the intellectual capacity to sort of address these whole questions."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_450 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_37,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_451 ;
    neo:id "fab28844e07ff55e0d41b3b14111ee16"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 22, sentence number 4 on page 0"^^xsd:string ;
    neo:text "They're part of what's being offered."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_452 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_273,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31 ;
    neo:id "ddda2b6cf74e1c93a11cddbc32a0c9d4"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 22, sentence number 5 on page 0"^^xsd:string ;
    neo:text "Different people will pick up different things."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_453 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_145,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31 ;
    neo:id "ac1c10568d77892fce79af1bc2363dea"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 22, sentence number 6 on page 0"^^xsd:string ;
    neo:text "Different people will be helped by different approaches."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_454 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_86 ;
    neo:id "6289af36793d53d8a8ff994d757b5037"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 22, sentence number 7 on page 0"^^xsd:string ;
    neo:text "So again, that's something that may be challenging at different times, but I hope that's okay, and it feels important."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_455 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_456,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_457 ;
    neo:id "931a7d74266708e7d2ec56b04b509af5"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 23, sentence number 1 on page 0"^^xsd:string ;
    neo:text "So open-mindedness, and, I also feel, humility."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_458 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_224,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_93 ;
    neo:id "49bff1ef266ab47ec8808b5b3beebcbd"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 23, sentence number 2 on page 0"^^xsd:string ;
    neo:text "Again, that sounds like a funny thing to be bringing up at the beginning of a retreat, or asking you for."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_459 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_108,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_22,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_331,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_45 ;
    neo:id "51b46f29afca6ce6f1c20a3359c39785"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 23, sentence number 3 on page 0"^^xsd:string ;
    neo:text "I feel, for many years, this has been a real central avenue of my practice, these teachings on emptiness and the whole area of emptiness, and I feel very, very humble still around all the teachings."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_46 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_41,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_47 ;
    neo:id "0f66e52bbebe17b23ee200ac9944fe3f"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 1, sentence number 9 on page 0"^^xsd:string ;
    neo:text "And then his teaching, in a way -- it's not obvious at first, but it was all centred around emptiness."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_460 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_461,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_86 ;
    neo:id "fbc505b705ad31be091e8120fcc33549"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 23, sentence number 4 on page 0"^^xsd:string ;
    neo:text "You know, there's stuff that I still feel I don't really understand it; I'm not sure."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_462 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_248,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_457 ;
    neo:id "0f8cfc1b665e5a4edb415271a791e824"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 23, sentence number 5 on page 0"^^xsd:string ;
    neo:text "But it's a sense of just keeping that sense [of humility]."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_463 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_22,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_24 ;
    neo:id "fd277d6e2bcd7c222744dd453780fd1d"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 23, sentence number 6 on page 0"^^xsd:string ;
    neo:text "As I said, a lot of the teachings are counterintuitive."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_464 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_248,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_35,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_465,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_466 ;
    neo:id "525133f7a2cc99202f011ef056f95795"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 23, sentence number 7 on page 0"^^xsd:string ;
    neo:text "The teachings of emptiness actually counter our general sense and intuition of reality."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_467 a neo:Document ;
    neo:id "91d1206a756237c69831271db45e1c9c"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 23, sentence number 8 on page 0"^^xsd:string ;
    neo:text "It's actually in the opposite direction of that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_468 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_28,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_457 ;
    neo:id "72d282bf1fc6dcc9f6d9d50ed1f8208d"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 23, sentence number 9 on page 0"^^xsd:string ;
    neo:text "So to me, it takes humility."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_469 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_22,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_413,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_470 ;
    neo:id "241238b88b3c73e5f53ea322867d4733"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 23, sentence number 10 on page 0"^^xsd:string ;
    neo:text "Sometimes, as I said, very difficult to understand, and there are levels and depths."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_471 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_51,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_99 ;
    neo:id "58f671a7a4e81588dd6f8ff32ce40f09"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 23, sentence number 11 on page 0"^^xsd:string ;
    neo:text "Even if we feel like, \"Oh, I understand that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_472 a neo:Document ;
    neo:id "43d6e5b263610d15497fb0ffb6b03070"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 23, sentence number 12 on page 0"^^xsd:string ;
    neo:text "I understand that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_473 a neo:Document ;
    neo:id "737a4f4fddcc6fdc67e5772853cbbd3e"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 23, sentence number 17 on page 0"^^xsd:string ;
    neo:text "It keeps going."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_474 a neo:Document ;
    neo:id "6e2f2e4059e5e0504b4369a8ca992cb8"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 23, sentence number 14 on page 0"^^xsd:string ;
    neo:text "Great, great, great,\" haven't reached the end yet."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_475 a neo:Document ;
    neo:id "7ab2f6e631aa7c9a6527a401d84d9be0"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 23, sentence number 15 on page 0"^^xsd:string ;
    neo:text "Haven't reached the end."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_476 a neo:Document ;
    neo:id "5e5684b8b265cd99ed4f23797a5f6277"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 23, sentence number 16 on page 0"^^xsd:string ;
    neo:text "I don't know."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_477 a neo:Document ;
    neo:id "60f814cac9ce193c94c4af30b78e4f11"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 23, sentence number 18 on page 0"^^xsd:string ;
    neo:text "It seems to just keep going."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_478 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_479 ;
    neo:id "bf8c8bd47f420e3c2f9e93674eb61ee2"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 23, sentence number 19 on page 0"^^xsd:string ;
    neo:text "For myself, it seems to just keep going."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_48 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_45,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_49 ;
    neo:id "84fccb31084a97fd746e2029e87070d1"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 1, sentence number 10 on page 0"^^xsd:string ;
    neo:text "We can say 'emptiness' and 'dependent origination' -- we'll be talking about these two -- they're two sides of the same coin."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_480 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_22,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_481 ;
    neo:id "df7b10fa96dbdbd828e772e8d90f9ca0"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 23, sentence number 20 on page 0"^^xsd:string ;
    neo:text "And to me, there's something beautiful about the necessity of humility there."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_482 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_380,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_483 ;
    neo:id "38dcbcc8eb1ba592297735c66a5a10f0"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 24, sentence number 1 on page 0"^^xsd:string ;
    neo:text "There's a teacher, Āryadeva."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_484 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_485 ;
    neo:id "929e5de454ea1391f819b5986e844223"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 24, sentence number 2 on page 0"^^xsd:string ;
    neo:text "We'll talk about him."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_486 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_34,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_44 ;
    neo:id "03d98e4cd47e73d0d087991fae82c509"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 24, sentence number 3 on page 0"^^xsd:string ;
    neo:text "He's a very important teacher, four or five hundred years after the Buddha."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_487 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_44,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_456 ;
    neo:id "4558bc2579a18257b0d7bafaf49d8abc"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 24, sentence number 4 on page 0"^^xsd:string ;
    neo:text "He's talking about this open-mindedness:"^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_488 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_45,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_66 ;
    neo:id "2909c225f248c49b9662c07d861aeac2"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 25, sentence number 1 on page 0"^^xsd:string ;
    neo:text "Those with little merit do not even entertain questions regarding this Dharma [these teachings of emptiness].[^footnote_2]"^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_489 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_133,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_37,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_393 ;
    neo:id "8b5064998d37993fe873902223498b47"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 26, sentence number 1 on page 0"^^xsd:string ;
    neo:text "They don't even entertain questions about it."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_490 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_491 ;
    neo:id "8fbb0df9001efd2582ab2809e5a5de4a"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 26, sentence number 2 on page 0"^^xsd:string ;
    neo:text "It's a closed door."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_492 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_493,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_494 ;
    neo:id "dcd3a099cd3dcebfd057326473f4f8dd"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 27, sentence number 1 on page 0"^^xsd:string ;
    neo:text "Even entertaining a question about it tears saṃsāra to shreds.[^footnote_2]"^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_495 a neo:__Entity__ ;
    neo:LEADS_TO ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_494 ;
    neo:id "Entertaining"^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_496 a neo:Document ;
    neo:id "0461d9ab46f45c9d75168defd57a271b"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 28, sentence number 1 on page 0"^^xsd:string ;
    neo:text "Then he says,"^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_497 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_45,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_465,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_498 ;
    neo:id "095ca4530f67af572bcdd5fb06b1fd34"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 29, sentence number 1 on page 0"^^xsd:string ;
    neo:text "When one sees reality [in other words, emptiness] one achieves a supreme abode.[^footnote_2]"^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_499 a neo:__Entity__ ;
    neo:ACHIEVES ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_498 ;
    neo:id "Seeing Reality"^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_50 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_44,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_51 ;
    neo:id "c3449941a84c593c23f938e54222c1c4"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 1, sentence number 11 on page 0"^^xsd:string ;
    neo:text "But he actually said, > \"First there is the understanding."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_500 a neo:Document ;
    neo:id "a93776f037231029be75537998884f6e"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 30, sentence number 1 on page 0"^^xsd:string ;
    neo:text "But this is the important bit:"^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_501 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_185,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_502 ;
    neo:id "0d8e3ffa143abc80dd43b498671f8abf"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 31, sentence number 1 on page 0"^^xsd:string ;
    neo:text "Even by seeing the slightest bit, one is better off.[^footnote_2]"^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_504 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_47 ;
    neo:id "07d39c2ef05bae75ad68349c3eeb324f"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 32, sentence number 1 on page 0"^^xsd:string ;
    neo:text "It's a very gradual teaching here."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_505 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_506 ;
    neo:id "dc8374ed453ba35e4759a6653151ed85"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 32, sentence number 2 on page 0"^^xsd:string ;
    neo:text "There's a spectrum."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_507 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_508,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_509,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_510 ;
    neo:id "7e6bd4b2f06a68633db2f4cb8618d2af"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 33, sentence number 1 on page 0"^^xsd:string ;
    neo:text "Therefore the wise should always cultivate such wisdom in contemplating phenomena.[^footnote_2]"^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_511 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_32,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_451 ;
    neo:id "a228bedd53fdae1b3232c50b3208fa98"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 34, sentence number 1 on page 0"^^xsd:string ;
    neo:text "A lot of this, or some of this, some of what's being offered, will be like planting seeds."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_513 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_128,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_133,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_514 ;
    neo:id "37fabbae3888a7866c71a1e35a8b5ca0"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 34, sentence number 2 on page 0"^^xsd:string ;
    neo:text "In other words, you will feel the fruit of a lot of it in these four weeks."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_515 a neo:Document ;
    neo:id "2e412d79cd93488d4c1c66378edb9947"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 34, sentence number 3 on page 0"^^xsd:string ;
    neo:text "I really hope that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_516 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_517,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_518 ;
    neo:id "2d5591ca10a79ed9331dd45d5910400a"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 34, sentence number 4 on page 0"^^xsd:string ;
    neo:text "And some, it may be that seeds sprout a couple of weeks later."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_519 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_133,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_254 ;
    neo:id "ede59054082158dbadc60ebdd96c7179"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 34, sentence number 5 on page 0"^^xsd:string ;
    neo:text "It may be years later."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_52 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_45,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_49,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_53 ;
    neo:id "e44085cab4f165f5e0fbd3147c9ae95f"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 1, sentence number 12 on page 0"^^xsd:string ;
    neo:text "First there is the realization of emptiness or dependent > origination, and then there is nibbāna.\"[^footnote_1]"^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_520 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_133,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_82 ;
    neo:id "2c11c8f37abdb63831c1e0eff8abcce7"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 34, sentence number 6 on page 0"^^xsd:string ;
    neo:text "It may be something you've completely forgotten about, but it will manifest later."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_521 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_522,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_523,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_524,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_525,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_526 ;
    neo:id "01b8107feb8f6bcfb6003aea14ed2287"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 35, sentence number 1 on page 0"^^xsd:string ;
    neo:text "[^footnote_1]: SN 12:70 ([Saṁyutta Nikāya (connected discourses on causation), Susimaparibbājakasutta](https://suttacentral.net/sn12.70/en/bodhi))."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_527 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_483,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_528,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_529,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_530,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_531,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_532,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_533,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_534,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_535,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_536,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_537 ;
    neo:id "b4d90e1dc3f11bfa15a934c7ffaf15f6"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 36, sentence number 1 on page 0"^^xsd:string ;
    neo:text "[^footnote_2]: This appears to be Rob's own translation of verses 180 and 196 from Āryadeva's Catuḥśataka. Part of this quotation is cited as a \"Translation from the author's notes\" in Rob Burbea, Seeing That Frees (Devon: Hermes Amāra, 2014), 8 n. 7. Cf. Āryadeva, Gyel-Tsap, and Geshe Sonam Rinchen, Āryadeva's Four Hundred Stanzas on the Middle Way: With Commentary by Gyel-Tsap, traduction Ruth Sonam (Ithaca, New York: Snow Lion Publications, 2008), 188, 197."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_539 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_23,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_34,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_45,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_49,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_53,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_540,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_66,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_69,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_70 ;
    neo:id "206efb466293859b00671f35601940d3"^^xsd:string ;
    neo:source "../jj_doc_Rob_Burbea/result_data/2010_01_20_-_Rob_Burbea_-_Meditation_on_emptiness_Retreat_-_Opening_talk_Orienting_and_relating_to_the_emptiness_retreat_-_local_converter.md"^^xsd:string ;
    neo:text """Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat

Beginning of the teaching

For me, this is really, really, I feel, very much a privilege for me to be able to offer these teachings, and I know John feels the same. It's very beautiful. For me, it's a very beautiful experience. It's beautiful to see so many people here, and that this inspires and calls you and attracts you, to me, is very touching. These teachings of emptiness, I think it's fair to say they're really at the heart of what the Buddha was teaching. They're really at the heart of the Buddha's path. They're at the heart of his awakening. Very much at the heart, the pith, the core of what he awakened to -- it was emptiness. And then his teaching, in a way -- it's not obvious at first, but it was all centred around emptiness. We can say 'emptiness' and 'dependent origination' -- we'll be talking about these two -- they're two sides of the same coin. But he actually said, > "First there is the understanding. First there is the realization of emptiness or dependent > origination, and then there is nibbāna."[^footnote_1]

They follow one from another very naturally. He was very clear about that. Without that, there isn't awakening, there isn't nibbāna. And so we say, "What did he wake up to?" He woke up to emptiness. He woke up to dependent origination.

Sometimes (and understandably), people can feel, or we can have a sense that these teachings of emptiness, or the meditations on emptiness, they're sort of the pinnacle of the teachings. They're like the cream or something, or it's a bit elitist or specialist: "Well, I might get into that, or I might not." And to a certain extent, that's true. But in another way, these teachings of emptiness actually permeate the whole of the Dharma, but it's not in a very obvious way. They permeate every teaching and every aspect that the Buddha ever talked about. So when we talk about generosity, when we talk about ethics, they actually have a lot to do with emptiness. It's not obvious at first, but the more one goes into this, the more one actually sees it's all kind of different strands, different facets of one teaching. Why is that? When I practise generosity, when I care about my ethics, something is getting unbound. We could say the tendency of the mind and the heart to grip something, to bind something -- me, worrying about me, concerned about me, and putting that first -- starts to get unbound. And that starts to have an effect. We can go very deep into emptiness through generosity, and also through caring about ethics.

We start to see something: that we build, we shape the world that we live in. We're going to talk a lot about this. I'll just say a tiny bit tonight. That actually ends up being part of the real core of what the emptiness message is: the world that we experience, the world that we perceive, that we feel to be what we naturally exist in, that's actually shaped by the heart and the qualities in the heart. And that's why generosity and ethics and all the rest of those teachings actually have a lot to do with emptiness."""^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_54 a neo:Document ;
    neo:id "1d2cf86c624e6176a5b7b59f78d80f64"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 2, sentence number 1 on page 0"^^xsd:string ;
    neo:text "They follow one from another very naturally."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_541 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_108,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_24,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_86,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_93,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_96 ;
    neo:id "f10a7a99bdc7e00b7a8b17d1b31df6c8"^^xsd:string ;
    neo:source "../jj_doc_Rob_Burbea/result_data/2010_01_20_-_Rob_Burbea_-_Meditation_on_emptiness_Retreat_-_Opening_talk_Orienting_and_relating_to_the_emptiness_retreat_-_local_converter.md"^^xsd:string ;
    neo:text """That's actually all I'm going to talk about emptiness, per se, tonight. What I really want to talk about tonight is how to relate to this retreat and how to relate to these teachings, just a little bit, and it's something we'll revisit. So I'm kind of wondering how you're feeling, how you're feeling tonight. Maybe you're just tired, and I know some have had a very long way to get here -- coming from California, etc. So you might be feeling tired. I hope if you're tired you can find some energy, because I feel like I have quite a lot I want to communicate. So I hope some energy can be roused. But other than just tired, if you are tired, sometimes people are really excited. There's something about these teachings, and they actually feel, and people have said to me, "I feel excited. I'm really looking forward." I love it when people feel excited about practice. I really enjoy that, and I think it's important that we do feel excited about the practice at times.

But equally, there might be -- and I would expect it -- some ambivalence. Some people feel maybe daunted -- maybe by the length of the retreat; maybe by the theme. And so this is a little bit what I want to go into. So tonight I want to talk about certainly some information and general stuff, but also about this relationship with the whole retreat. So what I'm saying tonight -- sometimes opening talks, you know, people are tired, and we just sort of say "hi," and kind of set a certain tone, and then "see you tomorrow, good night." So I'm hoping that what I say tonight you will remember, because it might not feel that important right now. Some people are doing this retreat for the second time. They did it last year. And they will recognize a lot of what I'm talking about, and actually it's quite important. So I hope that you can remember this over the retreat, which is four weeks, which is quite a long time to try and remember it. I'm actually not expecting you to remember it, but [laughs] saying it's quite important.

[8:03] So being on retreat is a challenge, and I'm sure many of you know that. It's challenging in different ways. This retreat has its own particular challenges as well as the usual challenges. It's actually quite challenging to teach. It's a very challenging retreat to teach. Part of what's challenging is that there's an enormous amount that we're communicating. It's going to feel like really a lot of material and a lot of possible approaches offered. There's a reason for that. I'm sure there are other ways to go about this, but this is what we've chosen. It's because everyone in here is different, and everyone in here has different practice backgrounds, and different histories, and different personalities, and different inclinations, etc. So everyone in here will probably be approaching this whole area quite differently. The idea is to kind of offer loads, and people find different bits to nibble on, and to follow different strands. I think at the beginning last year, I said it's a bit like a giant pizza, and it's in the room, and people will be starting to nibble from different directions. That's not a very good analogy. [laughter] Ultimately, everyone eats a whole pizza. Everyone eats the whole pizza, ultimately, in the end."""^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_542 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_128,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_166,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_168,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_171,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_189,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_194,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_203,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_207,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_211,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_212,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_23,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_24 ;
    neo:id "2e9447b28e5513b78fb824c6b9911b51"^^xsd:string ;
    neo:source "../jj_doc_Rob_Burbea/result_data/2010_01_20_-_Rob_Burbea_-_Meditation_on_emptiness_Retreat_-_Opening_talk_Orienting_and_relating_to_the_emptiness_retreat_-_local_converter.md"^^xsd:string ;
    neo:text """It's impossible to communicate everything at once. In other words, we'll be moving through -- obviously the teachings have to get communicated in time, so this, and then that, and then this, and then that. It may be that the order that the teachings get presented in is exactly the order that follows, and exactly at the right time that you feel it progresses exactly with your internal process. Hallelujah if it is. But it's probably not going to be that. It's probably going to feel like you're storing some stuff, and just leaving some stuff, and following other threads, etc. And that's all really, really fine. It's completely fine. Eventually, it will all fit together for you. And as I said, it's impossible to say it all at once. Sometimes one wishes that one can kind of say everything at once, and actually repeat this opening talk every day, but obviously it's impossible.

So did everyone get the message about the notebooks? I see lots of notebooks. Did everyone get that? Yeah? So this really isn't a study retreat. If study isn't your thing, don't be nervous. It's really not a study retreat, but there's, as I said, an enormous amount of teachings offered, an enormous amount of approaches, things to reflect on, subtleties, etc. And really that's what we want to do, John and I, is communicate something, give you something of the fullness of these teachings, the subtlety, the depth -- give you all of that, and the precision. There's a lot of real precision here, as well, rather than kind of having a practice that might be a little vague. So it's sometimes sad when people are left with a bit of a vague sense of what to do or how to go about practice. What we want is to really give you the know-how, how to practise in this area, and really practise well, and really know how to practise well. That's my hope.

So sometimes I think it would be better if this retreat was four months long, or actually four years long. There's a ton here. And it's okay. It's really okay. No one is going to get to all of what's being offered in four weeks. Well, I'm not saying it's impossible, but it would be very, very unlikely that anyone would get to all of it. Rather, what I'm hoping, as I sort of alluded to before, is that in everything that's offered, in the practices and approaches that are offered, each person finds one or two or maybe three approaches that work for you individually, and then you follow that. You follow strands, avenues of practice, and you develop that. They're going to be different for different people. So maybe one, or maybe a couple. But the key thing is finding what works, and then developing that, and taking it deeper, and seeing where it goes, rather than trying to do everything. But we do want to give, as I said, some sense of the width of the possible approaches, and where we're heading with all this, where all these teachings on emptiness are going -- some sense of that.

So again, what I really hope for, what I really wish to communicate and to offer and to give, is that you, on this retreat, learn new ways, new approaches, something that you haven't been able to do before -- that you learn how to do that; that you acquire a new skill, a new art, a new tool in meditation that works for you. And by 'working' for you, I mean you really sense that you can feel the freedom coming out of it. You feel, "I have some sense of how to do this, and I know that when I do it, I can actually feel the freedom." That's what we would wish for. So it's finding what works, experimenting for yourself."""^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_543 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_256,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_257,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_259,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_260,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_268,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_29,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_310,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_380,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_544,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_93 ;
    neo:id "c5565bbed1ec54c07393014ceabc2380"^^xsd:string ;
    neo:source "../jj_doc_Rob_Burbea/result_data/2010_01_20_-_Rob_Burbea_-_Meditation_on_emptiness_Retreat_-_Opening_talk_Orienting_and_relating_to_the_emptiness_retreat_-_local_converter.md"^^xsd:string ;
    neo:text """I've seen many, many times, over the years of teaching, there are people grappling, feeling like nothing is working, nothing is working, and eventually finding something, and being surprised with what comes with that. So I sometimes see meditation as a kind of art. It's an art and a craft, and we develop skills, we develop that art, and we really can do that. Partly what I want to communicate tonight is that really that is possible. You can do that. We can do that. So sometimes, as I said, it will feel a little bit daunting, or "I don't understand," or overwhelming, but we really can do this. I know it. Everyone can pick up something, find something that works here.

One of the sad things for me teaching sometimes is that -- I don't know proportions, but sometimes it seems to me that the majority of meditators actually grossly underestimate what they are personally capable of, what's actually possible for them. And because of that, they don't actually venture out and experiment with things. They don't even try to play and experiment with things. They just feel like, "I couldn't possibly do that." I have a real sense that it's a matter of finding one's way of working, as I said. Much, much more is possible for us as meditators than we tend to think -- much, much more.

[15:20] On this retreat -- it's only open to experienced meditators -- we're kind of presupposing a little bit that you are familiar with basic sort of mindfulness practice, and what it means to be mindful, what it means to pay attention to your experience and the different aspects and dimensions of your experience. We're kind of presupposing that, and presupposing that you feel able to be with your experience in that direct, mindful way, and open to it, and work with it like that. So that's a kind of presupposition. However, being realistic, it's true to say that maybe most people need more practice with that. You know, just that practice sounds simple, but as many of you know, it actually takes quite a while to really absorb that into one's meditative life, and really feel like, "I really feel comfortable knowing how to do that. I really feel comfortable with that sort of basic mindfulness and openness and ability to be with." For most people it takes years. It takes years to develop the capacity to do that and to feel really comfortable doing that.

So, though we are kind of presupposing it, it's something that we can still talk about. It's very much something that we can talk about, and sometimes we will talk just in those terms. And you can bring that level of things to interviews, and please do. But I guess what I'm asking is: don't just do that. Please, please, please, don't just do that. If you're familiar with just being mindful of your experience, don't just do that. And don't assume, as I was saying, that emptiness meditations are all difficult. They're not all difficult. Some of them may be very subtle. So you might have a kind of normal practice of just opening to things and being with things. It's fine sometimes. But see if you can really add to that, and build on that, and go beyond that."""^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_545 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_108,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_111,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_23,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_29,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_321,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_331,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_333,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_34,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_350,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_371,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_377,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_380,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_546,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_547,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_548,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_549,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_550,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_551,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_93 ;
    neo:id "d86f09b99ba80d8342cfd682a2de20b5"^^xsd:string ;
    neo:source "../jj_doc_Rob_Burbea/result_data/2010_01_20_-_Rob_Burbea_-_Meditation_on_emptiness_Retreat_-_Opening_talk_Orienting_and_relating_to_the_emptiness_retreat_-_local_converter.md"^^xsd:string ;
    neo:text """So to do that, to learn new practices, to open into realms of practice that we're not familiar with, for me, takes playing with. It's kind of a willingness to play with our practice, like a child playing with toys, and actually have fun with it, and experiment, and allow ourselves to be flexible that way. And then finding what works and consolidating that -- actually really absorbing that and making it more solid. You'll get lots of different opinions on this, but I really feel that it's highly, highly unlikely that someone 'just being with' their experience would stumble on the full depth and range and potency of the teachings on emptiness. It's an opinion, but I guess I hold that opinion, that it's unlikely that just being with the experience would open up that whole depth. It seems to me that we actually need to be a bit more directive in the practice, a bit more experimental, a bit more playing, listen to teachings, etc., and develop, as I said, specific approaches. So finding what works, playing, really playing with it, and then repeating, repeating that, following that avenue, taking it deeper, burrowing with that and seeing where it goes.

As I said before, every retreat (not for everyone, but for a lot of people) brings up all the usual retreat difficulties -- just stuff, whether it's about sleep, or about your work period job, or about where we sit, or the temperature of the room, or something about your shoes, or whatever it is. It's just normal stuff of retreat life. And again, I'm really hoping that you can remember all this for the whole four weeks, but I'm really hoping that what we're talking about in terms of formal practice actually gets transferred to all that other stuff, in terms of as we move around. Can I bring the same contemplations of emptiness, the same ways of looking, the same kind of ways of seeing things to all that difficulty too?

Okay. I think I mentioned before, but some people, and some people in this room, I'm sure, the idea of coming on a four-week retreat on emptiness, or even just the word 'emptiness,' it brings a welling up of joy and excitement and a kind of "yippee!" inside. Some people, that's what's there for them. They're probably in the minority, if that's the case. Probably in the minority. Most people have some ambivalence in relationship to teachings on emptiness, some degree of ambivalence. You may even be aware of some inside of you right now, or if you're not, it probably will come up at some point in the retreat. I can think, certainly from last year, and just over the years teaching this stuff, usually it's challenging, and it usually rocks the boat either a little bit or quite a lot. Even last year, people get quite angry. Some people get quite angry -- angry at me, angry at John, angry at Gaia House, angry at the teachings, angry at the Buddha. [laughter] It's not that uncommon. Another very common reaction is fear, fear around the teachings of emptiness, and fear around the experience of emptiness, and fear around the whole thing. And again, some people don't approach the teacher, or approach a certain amount and then go away because of that fear. There are different flavours of the fear, etc. Very, very common. Not 100 per cent, but for most people, it will bring up some degree of fear, in some way or another, at some point."""^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_55 a neo:Document ;
    neo:id "804f2614f5a19823a89f25a2853046a1"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 2, sentence number 2 on page 0"^^xsd:string ;
    neo:text "He was very clear about that."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_552 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_108,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_125,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_22,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_24,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_377,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_401,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_45,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_93 ;
    neo:id "3fadaae2f449bb119273720971f9bfea"^^xsd:string ;
    neo:source "../jj_doc_Rob_Burbea/result_data/2010_01_20_-_Rob_Burbea_-_Meditation_on_emptiness_Retreat_-_Opening_talk_Orienting_and_relating_to_the_emptiness_retreat_-_local_converter.md"^^xsd:string ;
    neo:text """I don't know if this will help, but there's nothing to fear. There's really nothing to fear. We'll talk more about this, I'm sure, in the interactions, and the talks, and the questions and answers and things. But there's really nothing to fear. It's actually moving in the opposite direction of fear and everything that goes with fear. But for most people, these teachings on emptiness, and moving in the practice of emptiness, and getting deeper is actually quite a gradual process, and not necessarily linear. And even the -- what could we say? -- the meditative experiences of emptiness, to whatever degree (a little bit, a lot, whatever), are kind of an acquired taste for most people. We're not quite sure, and we're just getting used to something that's a bit unfamiliar. All of that's very, very normal.

I could be wrong, but certainly if last year or other occasions and situations where I've taught this kind of thing (which is quite a lot) ... it could be that at times you feel very frustrated with the teachings, with everything. They're difficult to understand. I'll start probably tomorrow -- there's something about emptiness that's not difficult to understand at all, actually. It's so obvious, at one level, or levels of emptiness are so obvious. They're so kind of commonsensical. We're going to start there. And there are levels that are so counterintuitive and so mind-blowing and mind-boggling, and we've got all of that. They're difficult-to-understand teachings. To me, it takes time. It takes patience. And there can be at times some frustration. There can be at times some agitation with all of this. We hear something, and we wrestle, and we don't understand, or we don't like how it sounds, and the heart gets agitated. I, for one, have and I still do wrestle with different -- in the past, and wrestling with these teachings, and feeling agitated by them. And that's all, in a way, quite normal, and not necessarily a bad thing. It's part of the deepening process. It's part of the opening process.

This is going to sound funny, but I kind of feel like I would like to ask you to really keep an open mind, to try and keep that through four weeks. That sounds like a very funny thing to ask on retreat, because obviously we mostly show up on retreat with a very open mind. But again, experience from last year, etc., shows that, in different ways, we can struggle with a lot of what's being offered, and a lot of the teachings, and a lot of the concepts, and even the practice. So really asking to just keep checking the openness of the mind, the openness of the heart.

Some of the teachings and approaches -- some; I'm not sure what percentage, but some -- will be very non-conceptual, very sort of direct and simple. And some will be actually very conceptual. They will involve a lot of the thinking mind, the rational mind going into things and using the intellectual capacity to sort of address these whole questions. They're part of what's being offered. Different people will pick up different things. Different people will be helped by different approaches. So again, that's something that may be challenging at different times, but I hope that's okay, and it feels important."""^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_553 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_34,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_45,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_456,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_457,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_465,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_483,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_533,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_534,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_554 ;
    neo:id "415f96d6f5bd3a1b63a7a79b6f61bbb0"^^xsd:string ;
    neo:source "../jj_doc_Rob_Burbea/result_data/2010_01_20_-_Rob_Burbea_-_Meditation_on_emptiness_Retreat_-_Opening_talk_Orienting_and_relating_to_the_emptiness_retreat_-_local_converter.md"^^xsd:string ;
    neo:text """So open-mindedness, and, I also feel, humility. Again, that sounds like a funny thing to be bringing up at the beginning of a retreat, or asking you for. I feel, for many years, this has been a real central avenue of my practice, these teachings on emptiness and the whole area of emptiness, and I feel very, very humble still around all the teachings. You know, there's stuff that I still feel I don't really understand it; I'm not sure. But it's a sense of just keeping that sense [of humility]. As I said, a lot of the teachings are counterintuitive. The teachings of emptiness actually counter our general sense and intuition of reality. It's actually in the opposite direction of that. So to me, it takes humility. Sometimes, as I said, very difficult to understand, and there are levels and depths. Even if we feel like, "Oh, I understand that. I understand that. It keeps going. Great, great, great," haven't reached the end yet. Haven't reached the end. I don't know. It keeps going. It seems to just keep going. For myself, it seems to just keep going. And to me, there's something beautiful about the necessity of humility there.

There's a teacher, Āryadeva. We'll talk about him. He's a very important teacher, four or five hundred years after the Buddha. He's talking about this open-mindedness:

Those with little merit do not even entertain questions regarding this Dharma [these teachings of emptiness].[^footnote_2]

They don't even entertain questions about it. It's a closed door.

Even entertaining a question about it tears saṃsāra to shreds.[^footnote_2]

Then he says,

When one sees reality [in other words, emptiness] one achieves a supreme abode.[^footnote_2]

But this is the important bit:

Even by seeing the slightest bit, one is better off.[^footnote_2]

It's a very gradual teaching here. There's a spectrum.

Therefore the wise should always cultivate such wisdom in contemplating phenomena.[^footnote_2]

A lot of this, or some of this, some of what's being offered, will be like planting seeds. In other words, you will feel the fruit of a lot of it in these four weeks. I really hope that. And some, it may be that seeds sprout a couple of weeks later. It may be years later. It may be something you've completely forgotten about, but it will manifest later.

[^footnote_1]: SN 12:70 (Saṁyutta Nikāya (connected discourses on causation), Susimaparibbājakasutta).

[^footnote_2]: This appears to be Rob's own translation of verses 180 and 196 from Āryadeva's Catuḥśataka. Part of this quotation is cited as a "Translation from the author's notes" in Rob Burbea, Seeing That Frees (Devon: Hermes Amāra, 2014), 8 n. 7. Cf. Āryadeva, Gyel-Tsap, and Geshe Sonam Rinchen, Āryadeva's Four Hundred Stanzas on the Middle Way: With Commentary by Gyel-Tsap, traduction Ruth Sonam (Ithaca, New York: Snow Lion Publications, 2008), 188, 197."""^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_56 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_42,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_53 ;
    neo:id "99e4fd34ae357c5a650908bee3a400e9"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 2, sentence number 3 on page 0"^^xsd:string ;
    neo:text "Without that, there isn't awakening, there isn't nibbāna."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_57 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_44 ;
    neo:id "a089ec58b0edd7524ab179fecead2540"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 2, sentence number 4 on page 0"^^xsd:string ;
    neo:text "And so we say, \"What did he wake up to?\""^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_58 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_44,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_45 ;
    neo:id "08d3d7463054dc49b504e4d2e7ddb360"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 2, sentence number 5 on page 0"^^xsd:string ;
    neo:text "He woke up to emptiness."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_59 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_44,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_49 ;
    neo:id "ed11e47f4ee15944c0aca6cb70b4f509"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 2, sentence number 6 on page 0"^^xsd:string ;
    neo:text "He woke up to dependent origination."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_60 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_31,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_35,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_61 ;
    neo:id "9946fba881fd3ebc565ba3db5d856df5"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 3, sentence number 1 on page 0"^^xsd:string ;
    neo:text "Sometimes (and understandably), people can feel, or we can have a sense that these teachings of emptiness, or the meditations on emptiness, they're sort of the pinnacle of the teachings."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_62 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_37,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_63 ;
    neo:id "6bddcb1c2fd481e6c236925f14e6f3fe"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 3, sentence number 2 on page 0"^^xsd:string ;
    neo:text "They're like the cream or something, or it's a bit elitist or specialist: \"Well, I might get into that, or I might not.\""^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_64 a neo:Document ;
    neo:id "dadace12e270fb776e71e4b254650908"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 3, sentence number 3 on page 0"^^xsd:string ;
    neo:text "And to a certain extent, that's true."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_65 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_35,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_66 ;
    neo:id "ac4b1bdc39e281e20a0f06177ca653bb"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 3, sentence number 4 on page 0"^^xsd:string ;
    neo:text "But in another way, these teachings of emptiness actually permeate the whole of the Dharma, but it's not in a very obvious way."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_67 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_24,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_34 ;
    neo:id "eb00e1a59bdb63d6ed7f4de9055e37ed"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 3, sentence number 5 on page 0"^^xsd:string ;
    neo:text "They permeate every teaching and every aspect that the Buddha ever talked about."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_68 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_45,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_69,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_70 ;
    neo:id "2b846709bc4c298791f11cf4b6a57e53"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 3, sentence number 6 on page 0"^^xsd:string ;
    neo:text "So when we talk about generosity, when we talk about ethics, they actually have a lot to do with emptiness."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_71 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_47,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_72,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_73 ;
    neo:id "b18d179844e99e5db87e8a8b6dd28f42"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 3, sentence number 7 on page 0"^^xsd:string ;
    neo:text "It's not obvious at first, but the more one goes into this, the more one actually sees it's all kind of different strands, different facets of one teaching."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_74 a neo:Document ;
    neo:id "5f751c02301bece34939648576a9db21"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 3, sentence number 8 on page 0"^^xsd:string ;
    neo:text "Why is that?"^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_75 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_22,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_69,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_70 ;
    neo:id "f600ccec535f86eb800d6559b2135a6c"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 3, sentence number 9 on page 0"^^xsd:string ;
    neo:text "When I practise generosity, when I care about my ethics, something is getting unbound."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_76 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_28,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_38,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_77 ;
    neo:id "fbb966aab7d8b787e31464fd16593ab6"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 3, sentence number 10 on page 0"^^xsd:string ;
    neo:text "We could say the tendency of the mind and the heart to grip something, to bind something -- me, worrying about me, concerned about me, and putting that first -- starts to get unbound."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_78 a neo:Document ;
    neo:id "b09fd64be48641c3c9904b4ac861017a"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 3, sentence number 11 on page 0"^^xsd:string ;
    neo:text "And that starts to have an effect."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_79 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_45,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_69,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_70 ;
    neo:id "60d7baa95b00858069c5f0aef007d3d7"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 3, sentence number 12 on page 0"^^xsd:string ;
    neo:text "We can go very deep into emptiness through generosity, and also through caring about ethics."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_80 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_81,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_82,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_83 ;
    neo:id "0f6a02d0534693e2c1bd93bfe3537b1b"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 4, sentence number 1 on page 0"^^xsd:string ;
    neo:text "We start to see something: that we build, we shape the world that we live in."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_84 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_32 ;
    neo:id "239c07b3f1e86a0e384b3d10850b718f"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 4, sentence number 2 on page 0"^^xsd:string ;
    neo:text "We're going to talk a lot about this."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_85 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_86 ;
    neo:id "025c84341dcdf16729e96223304b9f87"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 4, sentence number 3 on page 0"^^xsd:string ;
    neo:text "I'll just say a tiny bit tonight."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_87 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_38,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_83,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_88 ;
    neo:id "1f84942dadccaad0e55ae46dabc0ee5a"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 4, sentence number 4 on page 0"^^xsd:string ;
    neo:text "That actually ends up being part of the real core of what the emptiness message is: the world that we experience, the world that we perceive, that we feel to be what we naturally exist in, that's actually shaped by the heart and the qualities in the heart."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_89 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_24,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_45,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_69,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_70 ;
    neo:id "cb1c6a195ac35f0ef9a3d0b94f32865d"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 4, sentence number 5 on page 0"^^xsd:string ;
    neo:text "And that's why generosity and ethics and all the rest of those teachings actually have a lot to do with emptiness."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_90 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_45,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_91 ;
    neo:id "47683afd659c599073e5aab44c7ca22a"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 5, sentence number 1 on page 0"^^xsd:string ;
    neo:text "That's actually all I'm going to talk about emptiness, per se, tonight."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_92 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_24,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_93 ;
    neo:id "7110803a65483714137a20fcc00478a9"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 5, sentence number 2 on page 0"^^xsd:string ;
    neo:text "What I really want to talk about tonight is how to relate to this retreat and how to relate to these teachings, just a little bit, and it's something we'll revisit."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_94 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_86 ;
    neo:id "1b793366ffae4c845e0828add9f6aa18"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 5, sentence number 3 on page 0"^^xsd:string ;
    neo:text "So I'm kind of wondering how you're feeling, how you're feeling tonight."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_95 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_96,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_97 ;
    neo:id "be7b2b4f0c282d802e72d5bcc0f50bd4"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 5, sentence number 4 on page 0"^^xsd:string ;
    neo:text "Maybe you're just tired, and I know some have had a very long way to get here -- coming from California, etc."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_98 a neo:Document ;
    neo:MENTIONS ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_100,
        ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_99 ;
    neo:id "8a00bc1c1dc543e8797775ded06081a2"^^xsd:string ;
    neo:source "Source document: Meditation on emptiness (retreat): Opening talk, Orienting and relating to the emptiness retreat, Chapter: Beginning of the teaching, paragraph number 5, sentence number 5 on page 0"^^xsd:string ;
    neo:text "So you might be feeling tired."^^xsd:string .

ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_10 a neo:Concept,
        neo:__Entity__ ;
    neo:CRAVING ex:node_4_0cb66cac_5376_41bb_a5c5_0fc9c3db9760_2 ;
    neo:id "Longing"^^xsd:string .

